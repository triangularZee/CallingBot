OPENAI_API_KEY=
SUMMARY_PROVIDER=openai
OPENAI_SUMMARY_MODEL=gpt-5.4
# Either GEMINI_API_KEY or GOOGLE_AI_API_KEY works. GOOGLE_AI_API_KEY matches market_review.
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3000
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example
RECORDINGS_DIR=./recordings
OUTPUT_DIR=./outputs

# Zoom bot
ZOOM_BOT_NAME=AI Notes Bot
ZOOM_HEADLESS=false
ZOOM_RECORD_GAIN_DB=24
# Prefer the real PulseAudio virtual microphone on Linux. Set true only as a fallback.
ZOOM_USE_FAKE_MIC_FILE=false
# Long silent fake microphone duration, used only when ZOOM_USE_FAKE_MIC_FILE=true.
ZOOM_SILENT_MIC_SECONDS=28800
# Windows examples:
#   audio=Stereo Mix (Realtek(R) Audio)
#   audio=CABLE Output (VB-Audio Virtual Cable)
# macOS example:
#   :0
# Linux example:
#   default
AUDIO_INPUT_DEVICE=audio=Stereo Mix (Realtek(R) Audio)
FFMPEG_PATH=ffmpeg

# Twilio call bot
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Optional comma-separated numeric chat IDs. TELEGRAM_CHAT_ID also works for market_review compatibility.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CHAT_ID=
