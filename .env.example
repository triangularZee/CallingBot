OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3000
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example
RECORDINGS_DIR=./recordings
OUTPUT_DIR=./outputs

# Zoom bot
ZOOM_BOT_NAME=AI Notes Bot
ZOOM_HEADLESS=false
# Windows examples:
#   audio=Stereo Mix (Realtek(R) Audio)
#   audio=CABLE Output (VB-Audio Virtual Cable)
# macOS example:
#   :0
# Linux example:
#   default
AUDIO_INPUT_DEVICE=audio=Stereo Mix (Realtek(R) Audio)
FFMPEG_PATH=ffmpeg

# Twilio call bot
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Optional comma-separated numeric chat IDs. Leave blank to allow any chat.
TELEGRAM_ALLOWED_CHAT_IDS=
