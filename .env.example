OPENAI_API_KEY=
SUMMARY_PROVIDER=openai
OPENAI_SUMMARY_MODEL=gpt-5.4
# Either GEMINI_API_KEY or GOOGLE_AI_API_KEY works. GOOGLE_AI_API_KEY matches market_review.
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3000
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example
RECORDINGS_DIR=./recordings
OUTPUT_DIR=./outputs

# Zoom bot — identity
# Leave ZOOM_BOT_NAME empty to randomize per run (recommended for anti-bot avoidance).
# Or provide a comma-separated pool via ZOOM_BOT_NAME_POOL.
ZOOM_BOT_NAME=
ZOOM_BOT_NAME_POOL=
ZOOM_RANDOMIZE_NAME=true

# Zoom bot — browser / stealth
ZOOM_HEADLESS=false
ZOOM_USE_STEALTH=true
# Optional. 'chrome' or 'chrome-beta' to use real Chrome instead of bundled Chromium.
ZOOM_CHROME_CHANNEL=
# Where the signed-in Zoom Pro session is cached. Run `npm run zoom:login` once.
ZOOM_STORAGE_STATE_PATH=./state/zoom-storage-state.json
# Optional UA override. Default: recent Chrome on Linux desktop.
ZOOM_USER_AGENT=
ZOOM_LOCALE=ko-KR
ZOOM_TIMEZONE_ID=Asia/Seoul
ZOOM_VIEWPORT=1280x720

# Zoom bot — humanization
ZOOM_CLICK_JITTER_MIN_MS=120
ZOOM_CLICK_JITTER_MAX_MS=480

# Zoom bot — recording / audio
ZOOM_RECORD_GAIN_DB=24
# Prefer the real PulseAudio virtual microphone on Linux. Set true only as a fallback.
ZOOM_USE_FAKE_MIC_FILE=false
# Long silent fake microphone duration, used only when ZOOM_USE_FAKE_MIC_FILE=true.
ZOOM_SILENT_MIC_SECONDS=28800
# Ambient mic noise — set to false to disable. Amplitude defaults to 0.004 (~-48dBFS).
ZOOM_ENABLE_AMBIENT_MIC=true
ZOOM_AMBIENT_AMPLITUDE=0.004
# Optional path to a WAV/MP3 file to use as ambient noise loop instead of generated brown noise.
ZOOM_AMBIENT_FILE=

# Zoom bot — virtual camera (Linux + v4l2loopback)
ZOOM_ENABLE_VIRTUAL_CAMERA=true
ZOOM_VIRTUAL_CAMERA=/dev/video10
ZOOM_VIRTUAL_CAMERA_LABEL=ZoomBotCam
# Optional looped MP4 (preferred). If absent, falls back to ZOOM_VIRTUAL_CAMERA_IMAGE.
ZOOM_VIRTUAL_CAMERA_FILE=
# Default: ./assets/bot-camera.png
ZOOM_VIRTUAL_CAMERA_IMAGE=

# Zoom bot — residential proxy (recommended over EC2 datacenter IPs)
ZOOM_PROXY_SERVER=
ZOOM_PROXY_USERNAME=
ZOOM_PROXY_PASSWORD=
ZOOM_PROXY_BYPASS=

# Windows examples:
#   audio=Stereo Mix (Realtek(R) Audio)
#   audio=CABLE Output (VB-Audio Virtual Cable)
# macOS example:
#   :0
# Linux example:
#   default
AUDIO_INPUT_DEVICE=audio=Stereo Mix (Realtek(R) Audio)
FFMPEG_PATH=ffmpeg
# STT files longer than TRANSCRIPTION_SINGLE_MAX_SECONDS are automatically split.
TRANSCRIPTION_SINGLE_MAX_SECONDS=1300
TRANSCRIPTION_CHUNK_SECONDS=600
TRANSCRIPTION_CHUNK_OVERLAP_SECONDS=8

# Twilio call bot
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Optional comma-separated numeric chat IDs. TELEGRAM_CHAT_ID also works for market_review compatibility.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CHAT_ID=
